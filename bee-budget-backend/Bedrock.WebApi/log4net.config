<?xml version="1.0" encoding="utf-8" ?>
<log4net>
	<!-- 定义一个名为 RollingFileAppender 的滚动文件附加器 -->
	<appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
		<!-- 日志文件的基本路径和名称 -->
		<file value="logs/app.log" />

		<!-- 是否追加到现有文件 -->
		<appendToFile value="true" />

		<!-- 滚动模式，这里设置为按日期滚动 -->
		<rollingStyle value="Date" />

		<!-- 最多保留的文件数，设为"-1"则不限（因为按日期存储，所以这里表示30天的数据） -->
		<!--<maxSizeRollBackups value="30"/>-->

		<!-- 按日期滚动的日志文件命名格式，例如 app.20231231.txt -->
		<datePattern value=".yyyyMMdd'.txt'" />

		<!-- 是否使用静态日志文件名，默认情况下会根据 datePattern 生成不同的文件名 -->
		<staticLogFileName value="false" />

		<!-- 定义日志消息的布局 -->
		<layout type="log4net.Layout.PatternLayout">
			<!-- 日志消息的格式化字符串 -->
			<conversionPattern value="%date [%thread] %-5level %logger - %message%newline" />
		</layout>
	</appender>

	<!-- 定义根记录器（root logger） -->
	<root>
		<!-- 设置根记录器的日志级别为 DEBUG，表示记录所有级别的日志 -->
		<level value="DEBUG" />

		<!-- 引用前面定义的 RollingFileAppender -->
		<appender-ref ref="RollingFileAppender" />
	</root>
</log4net>