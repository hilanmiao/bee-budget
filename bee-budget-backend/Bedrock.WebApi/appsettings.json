{
  // 应用设置
  "AppSettings": {
    // 应用监听的HTTP端口号
    "HttpPort": 20001,
    // 系统业务基准时区
    // 注意：此配置独立于服务器操作系统时区，请勿依赖 TimeZoneInfo.Local。请使用标准 IANA 格式，如 'Asia/Shanghai'、'UTC'
    "TimeZoneId": "Asia/Shanghai"
  },

  // 允许访问API的所有主机列表。"*"表示允许所有主机访问。
  "AllowedHosts": "*",

  // CORS 配置节
  "Cors": {
    // 设置为 true 时，允许所有来源（常用于开发环境）
    // 注意：生产环境应设为 false 并指定具体域名
    "AllowAllOrigins": true,

    // 当 AllowAllOrigins 为 false 时，仅允许以下来源
    "AllowedOrigins": [
      "https://example.com",
      "https://localhost:5001",
      "http://localhost:3000"
    ]
  },

  // Serilog 日志配置
  // 使用结构化 JSON 格式输出日志，便于日志平台（如 Seq、ELK、Loki）解析和查询
  "Serilog": {
    // 最低日志级别
    "MinimumLevel": "Information",

    // 定义日志输出目标（Sinks）
    "WriteTo": [
      {
        // 输出到控制台（开发调试用）
        // 使用紧凑型 JSON 格式，保留结构化字段（如 UserId、OrderId 等）
        "Name": "Console",
        "Args": {
          // 使用 RenderedCompactJsonFormatter：将日志渲染为单行 JSON
          // 自动包含时间戳(@t)、消息(@m)、级别(@l) 和所有结构化属性
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        // 输出到文件（生产环境核心日志）
        "Name": "File",
        "Args": {
          // 日志文件路径。'-' 会被替换为日期，例如：logs/app-20251201.json
          "path": "logs/app-.json",

          // 使用与控制台相同的 JSON 格式，确保一致性
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact",

          // 按天滚动日志文件（每天生成一个新文件）
          "rollingInterval": "Day",

          // 最多保留 30 个日志文件（即最近 30 天）
          "retainedFileCountLimit": 365,

          // 单个文件大小限制，默认为 10 MB，如果超过限制，将创建新的文件
          "fileSizeLimitBytes": 10485760,

          // 共享写入锁，允许多进程/线程安全写入（默认 true）
          "shared": true
        }
      }
    ]

    //// 可选：丰富日志上下文（需安装对应 NuGet 包，如 Serilog.Enrichers.Thread）
    //// 启用后可自动添加 MachineName、ThreadId、EnvironmentUserName 等字段
    //"Enrich": [
    //  "FromLogContext", // 支持 LogContext.PushProperty()
    //  "WithMachineName", // 添加 {MachineName}
    //  "WithThreadId" // 添加 {ThreadId}
    //],

    //// 可选：为所有日志事件添加固定属性（全局标签）
    //"Properties": {
    //  "Application": "Bedrock.Application",
    //  "Version": "1.0.0"
    //}
  },

  //// 日志级别配置
  //"Logging": {
  //  "LogLevel": {
  //    // 默认日志级别，适用于所有未明确指定的日志类别
  //    "Default": "Information",

  //    // 特定于Microsoft.AspNetCore框架组件的日志级别
  //    "Microsoft.AspNetCore": "Warning"
  //  }
  //},

  // 数据库连接字符串配置
  "Database": {
    // 默认数据库连接字符串，用于连接到MySQL数据库。
    // 格式：server=服务器地址;userid=用户名;password=密码;port=端口号;database=数据库名;charset=字符集;
    "DefaultConnection": "server=localhost;userid=root;password=ab@123;port=3306;database=bee_budget;charset=utf8mb4;Allow User Variables=True;Convert Zero Datetime=True;",
    // 默认数据库类型字符串。SqlSugar 支持的类型字符串: SqlServer, MySql, PostgreSQL, Oracle, Sqlite 等。
    //"DefaultDbType": "SqlServer"
    "DefaultDbType": "MySql"
  },

  // Redis缓存服务配置
  "Redis": {
    // Redis服务器连接字符串。可以包含密码等信息。
    // 示例："localhost:6379,password=your_redis_password"。当前设置为不带密码。
    "Configuration": "localhost:6379",

    // Redis实例名称（可选）。如果在同一台机器上运行多个Redis实例，可以使用不同的实例名称来区分它们。
    "InstanceName": "BeeBudget",

    // Redis数据库索引，默认为0
    "DefaultDatabase": 0
  },

  // 健康检查服务配置
  "HealthChecks": {
    // 数据库连接字符串配置
    "DatabaseConnection": "server=localhost;userid=root;password=ab@123;port=3306;database=bee_budget_health_checks;charset=utf8mb4;Allow User Variables=True;Convert Zero Datetime=True;",
    "HealthApiUrl": "http://localhost:20001/health"
  },

  // Hangfire后台任务调度服务配置
  "Hangfire": {
    // 数据库连接字符串配置
    "DatabaseConnection": "server=localhost;userid=root;password=ab@123;port=3306;database=bee_budget_hangfire;charset=utf8mb4;Allow User Variables=True;Convert Zero Datetime=True;"
  },

  // Token清理服务配置
  "TokenCleanup": {
    // 定时清理间隔，默认30分钟
    "CleanupInterval": 30
  },

  // JWT令牌生成和验证相关的配置
  "Jwt": {
    // 用于签名JWT的安全密钥，必须足够长以保证安全性（至少32字节或字符）
    "Key": "aVeryLongSecretKeyThatIsAtLeast32BytesOrCharactersInLength",

    // JWT的发布者（Issuer），通常是一个URL或标识符
    "Issuer": "your_issuer",

    // JWT的目标受众（Audience），通常是一个URL或标识符
    "Audience": "your_audience",

    // 访问令牌的有效期，单位为分钟
    "ExpiryMinutes": 120,

    // 刷新令牌的有效期，单位为天。刷新令牌通常比访问令牌有效期更长。
    "RefreshTokenExpiryDays": 30
  }

}